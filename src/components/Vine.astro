---
/**
 * Signature climbing vine. Decorative (aria-hidden).
 * On load the stem "draws" itself and leaves unfurl in sequence; both are
 * disabled under prefers-reduced-motion (see global.css). Purely CSS —
 * no client JS.
 */
interface Props {
  class?: string;
}
const { class: className } = Astro.props;

// Anchor points + rotations for the leaves that branch off the stem.
const leaves = [
  { x: 70, y: 322, r: -38, d: "0.9s" },
  { x: 73, y: 250, r: 44, d: "1.15s" },
  { x: 71, y: 190, r: -46, d: "1.4s" },
  { x: 70, y: 128, r: 36, d: "1.65s" },
  { x: 69, y: 78, r: -30, d: "1.9s" },
];
---

<svg
  class={className}
  viewBox="0 0 140 460"
  fill="none"
  stroke="currentColor"
  stroke-width="2"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
>
  <!-- meandering stem, bottom to top -->
  <path
    class="vine-stem"
    pathLength="1"
    d="M70 454 C 40 402 100 374 70 322 C 44 278 104 252 72 196 C 46 156 96 132 70 84 C 56 58 82 42 68 16"
  ></path>

  <!-- tendril curl at the growing tip -->
  <path
    class="vine-tendril"
    pathLength="1"
    d="M68 16 c 7 -4 12 -10 6 -15 c -4 -3 -9 0 -8 4 c 1 3 6 2 6 -2"></path>

  {
    /* Outer group positions the leaf (SVG transform); inner group carries the
       CSS unfurl animation so the two transforms don't clash. */
    leaves.map((leaf) => (
      <g transform={`translate(${leaf.x} ${leaf.y}) rotate(${leaf.r})`}>
        <g class="vine-leaf" style={`--leaf-delay:${leaf.d}`}>
          <path d="M0 0 C -6 -4 -6 -13 0 -17 C 6 -13 6 -4 0 0 Z" />
          <path d="M0 -1.5 V -15" stroke-width="1.2" />
        </g>
      </g>
    ))
  }
</svg>
