---
/**
 * Decorative botanical divider. Purely ornamental (aria-hidden).
 * `variant` picks the centre motif so sections can alternate:
 *   - "vein"    a pressed leaf with veins (default)
 *   - "sprig"   a small three-leaf sprig
 *   - "seed"    a winged seed / samara
 */
interface Props {
  class?: string;
  variant?: "vein" | "sprig" | "seed";
}
const { class: className, variant = "vein" } = Astro.props;
---

<svg
  class={className}
  viewBox="0 0 160 24"
  fill="none"
  stroke="currentColor"
  stroke-width="1"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
>
  <!-- trailing stems -->
  <path d="M4 12h60"></path>
  <path d="M96 12h60"></path>

  {
    variant === "vein" && (
      <g>
        <path
          d="M80 4c-4.5 2.4-7.5 5-7.5 8s3 5.6 7.5 8c4.5-2.4 7.5-5 7.5-8s-3-5.6-7.5-8z"
          stroke-width="1.2"
        />
        <path d="M80 5.5v13" />
        <path d="M80 9l-3.8 2.6M80 9l3.8 2.6M80 13l-3.2 2.2M80 13l3.2 2.2" />
      </g>
    )
  }

  {
    variant === "sprig" && (
      <g stroke-width="1.1">
        <path d="M80 20V6" />
        <path d="M80 12c-2.6-.4-5-2-6-4.6 2.7-.3 5 .9 6 3" />
        <path d="M80 12c2.6-.4 5-2 6-4.6-2.7-.3-5 .9-6 3" />
        <path d="M80 7.5c0-1.8 1.1-3.4 2.8-4.2C82.9 5 82 6.6 80 7.5z" />
      </g>
    )
  }

  {
    variant === "seed" && (
      <g stroke-width="1.1">
        <path d="M80 18v-6" />
        <path d="M80 12c-1.4-3.4-4.6-5.6-8.4-5.2C71 10 74.4 12 80 12z" />
        <path d="M80 12c1.4-3.4 4.6-5.6 8.4-5.2C89 10 85.6 12 80 12z" />
        <circle cx="80" cy="13.4" r="1.3" fill="currentColor" stroke="none" />
      </g>
    )
  }
</svg>
